{
  "name": "subzero-md",
  "version": "7.0.0",
  "description": "SubZero MD - Advanced WhatsApp Bot by Mr Frank 🇿🇼",
  "type": "module",
  "main": "dist/index.js",

  "engines": {
    "node": "20.x"
  },

  "directories": {
    "assets": "assets",
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },

  "scripts": {
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "build": "tsc && (cp -r assets dist/ || true)",
    "clean": "node -e \"import('fs').then(f=>f.default.rmSync('dist',{recursive:true,force:true}))\"",
    "rebuild": "npm run clean && npm run build",
    "dev": "tsc --watch & nodemon --watch dist --ext js dist/index.js",
    "pm2": "pm2 start dist/index.js --name subzero-md",
    "pm2:stop": "pm2 stop subzero-md",
    "pm2:restart": "pm2 restart subzero-md",
    "pm2:logs": "pm2 logs subzero-md",
    "setup": "npm run build && node dist/reset-data.js",
    "reset-data": "node dist/reset-data.js",
    "reset-session": "node -e \"import('fs').then(f=>f.default.rmSync('./session',{recursive:true,force:true})).then(()=>console.log('Session cleared!'))\"",
    "typecheck": "tsc --noEmit"
  },

  "keywords": [
    "whatsapp-bot",
    "baileys-bot",
    "subzero",
    "subzero-md",
    "mr-frank",
    "multi-device",
    "nodejs-bot",
    "typescript-bot"
  ],

  "homepage": "https://github.com/mrfr8nk/SUBZERO-MD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrfr8nk/SUBZERO-MD.git"
  },
  "bugs": {
    "url": "https://github.com/mrfr8nk/SUBZERO-MD/issues"
  },

  "license": "MIT",
  "author": "Mr Frank 🇿🇼",

  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.8.4",
    "adm-zip": "*",
    "better-sqlite3": "^12.5.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "ffmpeg": "^0.0.4",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^19.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "fs-extra": "^11.3.0",
    "gspeak": "^0.0.3",
    "human-readable": "^0.2.1",
    "jimp": "^1.6.0",
    "libphonenumber-js": "^1.11.18",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.43",
    "mongoose": "^9.0.2",
    "mumaker": "^2.0.0",
    "mysql2": "^3.16.0",
    "node-cache": "^5.1.2",
    "node-webpmux": "^3.1.7",
    "pdfkit": "^0.16.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "ruhend-scraper": "^9.0.8",
    "sequelize": "^6.37.6",
    "sharp": "^0.34.0",
    "simple-git": "^3.30.0",
    "sqlite3": "^5.1.7",
    "syntax-error": "^1.4.0",
    "wa-sticker-formatter": "^4.0.6",
    "yt-search": "^2.12.1"
  },

  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.5",
    "@types/pdfkit": "^0.13.8",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "nodemon": "^3.1.14",
    "pm2": "^5.4.3",
    "typescript": "^5.0.0"
  }
}
